pipeline {
    agent any

    environment {
        DOCKERHUB_CREDS = credentials('DevOps_lw2')
        LC_ALL = "en_US.UTF-8"
        LANG = "en_US.UTF-8"
        LANGUAGE = "en_US.UTF-8"
    }

    options {
        timestamps()
        skipDefaultCheckout(true)
    }

    stages {
        stage('Clone repository') {
            steps {
                cleanWs()
                bat 'chcp 65001 && git clone -b main https://github.com/DemonStage0/DevOps_lw2.git'
            }
        }

        stage('Login to DockerHub') {
            steps {
                bat 'chcp 65001 && docker login -u %DOCKERHUB_CREDS_USR% -p %DOCKERHUB_CREDS_PSW%'
            }
        }

        stage('Pull Docker images') {
            steps {
                bat 'chcp 65001 && docker pull altairzero/devops_lw2:latest && docker pull postgres:15'
            }
        }

        stage('Stop and remove old containers') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw2 && docker-compose down -v 2>nul || echo Containers not running'
            }
        }

        stage('Start services') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw2 && docker-compose up -d'
            }
        }

        stage('Wait for services') {
            steps {
                script {
                    bat 'chcp 65001 && ping -n 21 127.0.0.1 > nul'
                }
            }
        }

        stage('Check services status') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw2 && docker-compose ps'
            }
        }

        stage('Functional test - Health check') {
            steps {
                bat 'chcp 65001 && curl -s http://localhost:8000/ || exit 1'
            }
        }

        stage('Functional test - Train model') {
            steps {
                bat 'chcp 65001 && curl -s http://localhost:8000/train'
            }
        }

        stage('Functional test - Predict #1') {
            steps {
                bat 'chcp 65001 && curl -s "http://localhost:8000/predict?RI=1.52101&Na=13.64&Mg=4.49&Al=1.1&Si=71.78&K=0.06&Ca=8.75&Ba=0.0&Fe=0.0"'
            }
        }

        stage('Functional test - Predict #2') {
            steps {
                bat 'chcp 65001 && curl -s "http://localhost:8000/predict?RI=1.51761&Na=13.89&Mg=3.6&Al=1.36&Si=72.73&K=0.48&Ca=7.83&Ba=0.0&Fe=0.0"'
            }
        }

        stage('Check container logs') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw2 && docker-compose logs --tail 50'
            }
        }
    }

    post {
        always {
            bat '''
                chcp 65001
                cd DevOps_lw2 2>nul || echo Directory not found
                IF EXIST docker-compose.yml (
                    docker-compose down -v
                )
                docker logout
            '''
        }
        success {
            echo 'CD Pipeline completed successfully! All functional tests passed!'
        }
        failure {
            echo 'CD Pipeline failed! Check logs for details.'
        }
    }
}