pipeline {
    agent any

    environment {
        DOCKERHUB_CREDS = credentials('DevOps_lw2')
        LC_ALL = "en_US.UTF-8"
        LANG = "en_US.UTF-8"
        LANGUAGE = "en_US.UTF-8"
    }

    options {
        timestamps()
        skipDefaultCheckout(true)
    }

    stages {
        stage('Clone repository') {
            steps {
                cleanWs()
                bat 'chcp 65001 && git clone -b main https://github.com/DemonStage0/DevOps_lw2.git'
            }
        }

        stage('Checkout repo dir') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw2 && dir'
            }
        }

        stage('Login to DockerHub') {
            steps {
                bat 'chcp 65001 && docker login -u %DOCKERHUB_CREDS_USR% -p %DOCKERHUB_CREDS_PSW%'
            }
        }

        stage('Build images') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw2 && docker-compose build --no-cache'
            }
        }

        stage('Start services') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw2 && docker-compose up -d'
            }
        }

        stage('Wait for services') {
            steps {
                // Используем ping вместо timeout
                bat 'chcp 65001 && ping -n 16 127.0.0.1 > nul'
            }
        }

        stage('Check services status') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw2 && docker-compose ps'
            }
        }

        stage('Run unit tests') {
            steps {
                bat '''
                    chcp 65001
                    cd DevOps_lw2
                    for /f "tokens=*" %%i in ('docker ps -qf "name=^devops_lw2-web-1"') do set containerId=%%i
                    IF "!containerId!" == "" (
                        echo "No web container running"
                        exit 1
                    ) ELSE (
                        echo Running unit tests...
                        docker exec !containerId! python -m pytest src/unit_tests/ -v
                    )
                '''
            }
        }

        stage('Functional test - Health check') {
            steps {
                bat 'chcp 65001 && curl -s http://localhost:8000/'
            }
        }

        stage('Functional test - Train model') {
            steps {
                bat 'chcp 65001 && curl -s http://localhost:8000/train'
            }
        }

        stage('Functional test - Predict') {
            steps {
                bat 'chcp 65001 && curl -s "http://localhost:8000/predict?RI=1.52101&Na=13.64&Mg=4.49&Al=1.1&Si=71.78&K=0.06&Ca=8.75&Ba=0.0&Fe=0.0"'
            }
        }

        stage('Check container logs') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw2 && docker-compose logs --tail 50'
            }
        }

        stage('Tag and push image') {
            steps {
                bat 'chcp 65001 && cd DevOps_lw2 && docker tag devops_lw2-web:latest altairzero/devops_lw2:latest && docker push altairzero/devops_lw2:latest'
            }
        }
    }

    post {
        always {
            // Очистка в том же workspace, без node('windows')
            bat 'chcp 65001 && cd DevOps_lw2 && docker-compose down -v && docker logout'
        }
        success {
            echo 'CI Pipeline completed successfully!'
        }
        failure {
            echo 'CI Pipeline failed! Check logs.'
        }
    }
}