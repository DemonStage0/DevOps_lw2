pipeline {
    agent any
    environment {
        DOCKERHUB_CREDS = credentials('DevOps_lw2')
    }
    stages {
        stage('Login') {
            steps {
                bat 'docker login -u %DOCKERHUB_CREDS_USR% -p %DOCKERHUB_CREDS_PSW%'
            }
        }
        stage('Build') {
            steps {
                bat 'docker-compose build'
            }
        }
        stage('Run') {
            steps {
                bat 'docker-compose up -d'
            }
        }
    }
}